{
    "fallback_to_event_images": {
        "description": "Agent 未传入图片时回退读取消息图片",
        "type": "bool",
        "default": true,
        "hint": "当 Agent 调用工具时未传入 image_urls 参数，自动从当前消息/引用消息中提取图片。"
    },
    "default_image_config": {
        "description": "默认图片生成参数",
        "type": "object",
        "hint": "模型组未覆盖时的默认输出参数，对应 OpenAI 兼容请求中的 image_config 字段。",
        "items": {
            "aspect_ratio": {
                "description": "宽高比",
                "type": "string",
                "options": [
                    "default",
                    "1:1",
                    "2:3",
                    "3:2",
                    "3:4",
                    "4:3",
                    "9:16",
                    "16:9"
                ],
                "default": "default",
                "hint": "设为 default 时不发送此参数，由模型自行决定。"
            },
            "image_size": {
                "description": "图片尺寸",
                "type": "string",
                "options": [
                    "default",
                    "1K",
                    "2K"
                ],
                "default": "1K",
                "hint": "对应请求中的 image_config.image_size。"
            }
        }
    },
    "model_groups": {
        "description": "模型组配置",
        "type": "template_list",
        "hint": "每个模型组代表一种图片生成能力（如风格迁移、文生图等）。组内端点按顺序降级：第一个失败后自动尝试下一个。",
        "templates": {
            "openai_compatible": {
                "name": "OpenAI 兼容模型组",
                "hint": "适用于所有兼容 OpenAI Chat Completions 协议的端点（OpenRouter、NewAPI、火山引擎等）。",
                "items": {
                    "group_name": {
                        "description": "模型组名称",
                        "type": "string",
                        "default": "",
                        "hint": "唯一标识，Agent 通过此名称选择模型组。建议使用简短英文如 style_transfer、txt2img。"
                    },
                    "group_description": {
                        "description": "模型组简短描述",
                        "type": "string",
                        "default": "",
                        "hint": "显示在 Agent 工具说明中，帮助 Agent 理解该模型组的用途和擅长场景。"
                    },
                    "guide": {
                        "description": "Prompt 构建指南（给 Agent 看）",
                        "type": "text",
                        "default": "",
                        "hint": "教 Agent 如何为此模型构建最优 prompt 的详细指南。Agent 可先不传 prompt 来获取此指南。留空表示无需额外指导。此内容不会拼入最终 API 请求。"
                    },
                    "support_img2img": {
                        "description": "支持图生图",
                        "type": "bool",
                        "default": true
                    },
                    "support_txt2img": {
                        "description": "支持文生图",
                        "type": "bool",
                        "default": false
                    },
                    "default_operation": {
                        "description": "默认操作类型",
                        "type": "string",
                        "options": [
                            "img2img",
                            "txt2img"
                        ],
                        "default": "img2img",
                        "hint": "Agent 未指定 operation 时使用此默认值。"
                    },
                    "aspect_ratio_override": {
                        "description": "宽高比覆盖",
                        "type": "string",
                        "options": [
                            "inherit",
                            "default",
                            "1:1",
                            "2:3",
                            "3:2",
                            "3:4",
                            "4:3",
                            "9:16",
                            "16:9"
                        ],
                        "default": "inherit",
                        "hint": "inherit 表示继承全局 default_image_config 的值。"
                    },
                    "image_size_override": {
                        "description": "图片尺寸覆盖",
                        "type": "string",
                        "options": [
                            "inherit",
                            "default",
                            "1K",
                            "2K"
                        ],
                        "default": "inherit",
                        "hint": "inherit 表示继承全局 default_image_config 的值。"
                    },
                    "endpoints": {
                        "description": "端点列表（每行一个，从上到下依次降级）",
                        "type": "text",
                        "default": "# 格式：端点名称 | 地址 | API Key | 模型（端点名称可省略）\n# openrouter | https://openrouter.ai/api/v1/chat/completions | sk-xxx | google/gemini-3.1-flash-image-preview",
                        "hint": "每行一个端点，字段用 | 分隔。支持 4 段（名称|地址|密钥|模型）或 3 段（地址|密钥|模型，自动编号）。空行和 # 开头的行会忽略。如需禁用某端点，在行首加 # 即可。"
                    }
                }
            }
        }
    },
    "request": {
        "description": "请求参数配置",
        "type": "object",
        "items": {
            "timeout": {
                "description": "请求超时时间（秒）",
                "type": "int",
                "default": 120,
                "hint": "图片生成通常需要较长时间，建议不低于 60 秒。"
            },
            "max_retry": {
                "description": "每个端点的最大重试次数",
                "type": "int",
                "default": 2,
                "hint": "仅对 408、5xx、超时、网络异常生效。"
            }
        }
    },
    "image": {
        "description": "输入图片相关配置",
        "type": "object",
        "items": {
            "max_input_images": {
                "description": "最多读取的参考图片数量",
                "type": "int",
                "default": 3
            },
            "max_input_mb": {
                "description": "单张图片最大大小（MB）",
                "type": "int",
                "default": 20
            },
            "allow_reply_image": {
                "description": "是否读取引用/回复消息中的图片",
                "type": "bool",
                "default": true
            }
        }
    }
}
